<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
  <title>Taskflow</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #060510;
      --surface: rgba(255,255,255,0.045);
      --surface-hover: rgba(255,255,255,0.07);
      --border: rgba(255,255,255,0.08);
      --border-focus: rgba(168,130,255,0.6);
      --g1: #a882ff;
      --g2: #ff6eb4;
      --g3: #ffb86c;
      --text: #f0ecff;
      --muted: #7b748f;
      --done-text: #4d4860;
      --del: #ff6b7a;
      --radius: 18px;
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

    html, body {
      width: 100%; height: 100%;
      overflow: hidden;
    }

    body {
      font-family: 'Outfit', sans-serif;
      color: var(--text);
      background: var(--bg);
      display: flex;
      flex-direction: column;
    }

    /* ── LAUNCH SCREEN ─────────────────────────── */
    #launch {
      position: fixed; inset: 0; z-index: 100;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 1.4rem;
      background: var(--bg);
      animation: launchFade 0.55s ease 2.2s forwards;
    }

    @keyframes launchFade {
      to { opacity: 0; pointer-events: none; }
    }

    .launch-orb {
      width: 110px; height: 110px;
      border-radius: 50%;
      background: conic-gradient(from 180deg, var(--g1), var(--g2), var(--g3), var(--g1));
      filter: blur(0px);
      animation: orbSpin 2s linear infinite, orbPulse 1.8s ease-in-out infinite alternate;
      box-shadow: 0 0 60px rgba(168,130,255,0.5), 0 0 120px rgba(255,110,180,0.3);
    }

    @keyframes orbSpin  { to { transform: rotate(360deg); } }
    @keyframes orbPulse { to { transform: scale(1.12) rotate(360deg); } }

    .launch-title {
      font-family: 'Syne', sans-serif;
      font-size: 2.4rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      background: linear-gradient(135deg, var(--g1), var(--g2), var(--g3));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      animation: fadeUp 0.6s ease 0.3s both;
    }

    .launch-sub {
      font-size: 0.9rem;
      color: var(--muted);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      animation: fadeUp 0.6s ease 0.55s both;
    }

    .launch-bar {
      width: 140px; height: 3px;
      border-radius: 99px;
      background: var(--border);
      overflow: hidden;
      animation: fadeUp 0.6s ease 0.7s both;
    }

    .launch-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--g1), var(--g2), var(--g3));
      border-radius: 99px;
      animation: barFill 2s cubic-bezier(.4,0,.2,1) 0.4s forwards;
      width: 0;
    }

    @keyframes barFill { to { width: 100%; } }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: none; }
    }

    /* ── BACKGROUND MESH ───────────────────────── */
    .mesh {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      overflow: hidden;
    }
    .mesh-orb {
      position: absolute; border-radius: 50%;
      filter: blur(90px); opacity: 0.18;
    }
    .mesh-orb:nth-child(1) { width: 55vw; height: 55vw; background: var(--g1); top: -15%; left: -15%; }
    .mesh-orb:nth-child(2) { width: 45vw; height: 45vw; background: var(--g2); bottom: -10%; right: -10%; }
    .mesh-orb:nth-child(3) { width: 35vw; height: 35vw; background: var(--g3); top: 40%; left: 40%; }

    /* ── APP SHELL ─────────────────────────────── */
    #app {
      position: relative; z-index: 1;
      flex: 1;
      display: flex;
      flex-direction: column;
      height: 100dvh;
      max-width: 640px;
      width: 100%;
      margin: 0 auto;
      padding: 0;
    }

    /* ── HEADER ────────────────────────────────── */
    .header {
      padding: clamp(2rem,6vw,3.5rem) clamp(1.2rem,5vw,2rem) 1.2rem;
      flex-shrink: 0;
    }

    .eyebrow {
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.4rem;
    }

    .header h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2.2rem, 8vw, 3.2rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1;
      background: linear-gradient(135deg, #fff 0%, var(--g1) 60%, var(--g2) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }

    .stats-row {
      display: flex;
      gap: 1.2rem;
      margin-top: 1rem;
      font-size: 0.8rem;
      color: var(--muted);
    }

    .stat b { color: var(--g1); font-weight: 500; }

    /* ── LIST AREA ─────────────────────────────── */
    .list-wrap {
      flex: 1;
      overflow-y: auto;
      padding: 0.4rem clamp(1.2rem,5vw,2rem) 0.8rem;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,0.1) transparent;
    }

    .list-wrap::-webkit-scrollbar { width: 4px; }
    .list-wrap::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }

    #list { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }

    #list li {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1rem 1rem 1rem 1.1rem;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      animation: itemIn 0.3s cubic-bezier(.22,.68,0,1.2) both;
      transition: background 0.2s, border-color 0.2s;
    }

    #list li:active { background: var(--surface-hover); }

    @keyframes itemIn {
      from { opacity: 0; transform: translateY(-10px) scale(0.97); }
      to   { opacity: 1; transform: none; }
    }

    .check {
      width: 22px; height: 22px; flex-shrink: 0;
      border-radius: 50%;
      border: 2px solid var(--border);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.2s;
      background: transparent;
    }

    li.done .check {
      background: linear-gradient(135deg, var(--g1), var(--g2));
      border-color: transparent;
      box-shadow: 0 0 10px rgba(168,130,255,0.4);
    }

    li.done .check::after {
      content: '';
      width: 5px; height: 9px;
      border: 2px solid #fff;
      border-top: none; border-left: none;
      transform: rotate(43deg) translateY(-1px);
    }

    .item-text {
      flex: 1;
      font-size: clamp(0.9rem, 3vw, 1rem);
      font-weight: 400;
      color: var(--text);
      word-break: break-word;
      transition: color 0.2s;
    }

    li.done .item-text {
      color: var(--done-text);
      text-decoration: line-through;
    }

    .del-btn {
      background: transparent;
      border: 1px solid transparent;
      border-radius: 10px;
      color: var(--muted);
      font-size: 1rem;
      width: 34px; height: 34px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      flex-shrink: 0;
      transition: all 0.2s;
      -webkit-tap-highlight-color: transparent;
    }

    .del-btn:hover, .del-btn:active {
      color: var(--del);
      border-color: rgba(255,107,122,0.3);
      background: rgba(255,107,122,0.08);
    }

    /* ── EMPTY STATE ───────────────────────────── */
    #empty {
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.7rem;
      padding: 4rem 1rem;
      color: var(--muted);
      font-size: 0.9rem;
      text-align: center;
    }

    #empty.show { display: flex; }

    .empty-icon {
      font-size: 2.6rem;
      opacity: 0.35;
    }

    /* ── INPUT BAR ─────────────────────────────── */
    .input-bar {
      flex-shrink: 0;
      padding: clamp(0.8rem,3vw,1.2rem) clamp(1.2rem,5vw,2rem);
      padding-bottom: calc(clamp(0.8rem,3vw,1.2rem) + var(--safe-bottom));
      background: rgba(6,5,16,0.7);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-top: 1px solid var(--border);
    }

    .input-inner {
      display: flex;
      gap: 0.6rem;
      align-items: center;
      background: var(--surface);
      border: 1.5px solid var(--border);
      border-radius: 99px;
      padding: 0.5rem 0.5rem 0.5rem 1.2rem;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .input-inner:focus-within {
      border-color: var(--border-focus);
      box-shadow: 0 0 0 3px rgba(168,130,255,0.12);
    }

    #input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      font-family: 'Outfit', sans-serif;
      font-size: clamp(0.9rem,3.5vw,1rem);
      color: var(--text);
    }

    #input::placeholder { color: var(--muted); }

    #add {
      width: 44px; height: 44px;
      border-radius: 50%;
      border: none;
      background: linear-gradient(135deg, var(--g1), var(--g2));
      color: #fff;
      font-size: 1.4rem;
      font-weight: 300;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      transition: transform 0.15s, box-shadow 0.15s;
      box-shadow: 0 4px 18px rgba(168,130,255,0.35);
      -webkit-tap-highlight-color: transparent;
      line-height: 1;
    }

    #add:active { transform: scale(0.92); box-shadow: 0 2px 8px rgba(168,130,255,0.2); }

    /* ── CLEAR DONE CHIP ───────────────────────── */
    .actions-row {
      display: flex;
      justify-content: flex-end;
      padding: 0 clamp(1.2rem,5vw,2rem) 0.5rem;
      flex-shrink: 0;
    }

    .clear-btn {
      background: none;
      border: 1px solid var(--border);
      border-radius: 99px;
      color: var(--muted);
      font-size: 0.75rem;
      font-family: 'Outfit', sans-serif;
      padding: 0.3rem 0.85rem;
      cursor: pointer;
      transition: color 0.2s, border-color 0.2s;
      -webkit-tap-highlight-color: transparent;
    }

    .clear-btn:hover { color: var(--del); border-color: rgba(255,107,122,0.4); }
  </style>
</head>
<body>

  <!-- Launch Screen -->
  <div id="launch">
    <div class="launch-orb"></div>
    <div class="launch-title">Taskflow</div>
    <div class="launch-sub">Your daily companion</div>
    <div class="launch-bar"><div class="launch-bar-fill"></div></div>
  </div>

  <!-- Background mesh -->
  <div class="mesh">
    <div class="mesh-orb"></div>
    <div class="mesh-orb"></div>
    <div class="mesh-orb"></div>
  </div>

  <!-- App -->
  <div id="app">
    <!-- Header -->
    <div class="header">
      <p class="eyebrow">Today's focus</p>
      <h1>Taskflow</h1>
      <div class="stats-row">
        <span class="stat"><b id="total">0</b> tasks</span>
        <span class="stat"><b id="done-count">0</b> done</span>
      </div>
    </div>

    <!-- Actions -->
    <div class="actions-row">
      <button class="clear-btn" onclick="clearDone()">Clear completed</button>
    </div>

    <!-- List -->
    <div class="list-wrap">
      <ul id="list"></ul>
      <div id="empty">
        <span class="empty-icon">✦</span>
        <span>Nothing here yet.<br/>Add your first task below.</span>
      </div>
    </div>

    <!-- Input bar -->
    <div class="input-bar">
      <div class="input-inner">
        <input id="input" placeholder="What needs to be done?" autocomplete="off"/>
        <button id="add" onclick="add()" title="Add task">＋</button>
      </div>
    </div>
  </div>

  <script>
    var input     = document.getElementById('input');
    var list      = document.getElementById('list');
    var emptyEl   = document.getElementById('empty');
    var totalEl   = document.getElementById('total');
    var doneEl    = document.getElementById('done-count');

    input.addEventListener('keydown', function(e){ if(e.key==='Enter') add(); });

    function updateStats() {
      var all  = list.querySelectorAll('li');
      var done = list.querySelectorAll('li.done');
      totalEl.textContent = all.length;
      doneEl.textContent  = done.length;
      emptyEl.classList.toggle('show', all.length === 0);
    }

    function add() {
      var val = input.value.trim();
      if (!val) { input.focus(); return; }

      var li   = document.createElement('li');

      var chk  = document.createElement('div');
      chk.className = 'check';
      chk.setAttribute('role','checkbox');
      chk.setAttribute('aria-checked','false');
      chk.onclick = function(){
        li.classList.toggle('done');
        chk.setAttribute('aria-checked', li.classList.contains('done') ? 'true' : 'false');
        updateStats();
      };

      var txt  = document.createElement('span');
      txt.className = 'item-text';
      txt.textContent = val;

      var btn  = document.createElement('button');
      btn.className = 'del-btn';
      btn.innerHTML = '&#x2715;';
      btn.setAttribute('aria-label','Delete task');
      btn.onclick = function(){
        li.style.animation = 'none';
        li.style.transition = 'opacity 0.2s, transform 0.2s';
        li.style.opacity = '0';
        li.style.transform = 'scale(0.95)';
        setTimeout(function(){ li.remove(); updateStats(); }, 200);
      };

      li.appendChild(chk);
      li.appendChild(txt);
      li.appendChild(btn);
      list.appendChild(li);

      input.value = '';
      input.focus();
      updateStats();

      // scroll to bottom
      var wrap = document.querySelector('.list-wrap');
      setTimeout(function(){ wrap.scrollTop = wrap.scrollHeight; }, 50);
    }

    function clearDone() {
      list.querySelectorAll('li.done').forEach(function(li){
        li.style.transition = 'opacity 0.2s';
        li.style.opacity = '0';
        setTimeout(function(){ li.remove(); updateStats(); }, 200);
      });
    }

    updateStats();
  </script>
</body>
</html>


